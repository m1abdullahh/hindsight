{
  "default": {
    "identifier": "default",
    "description": "Default capability for the Hindsight desktop app",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "core:window:default",
      "core:window:allow-start-dragging",
      "core:window:allow-minimize",
      "core:window:allow-toggle-maximize",
      "core:window:allow-close",
      "core:event:default",
      "core:tray:default",
      "core:menu:default",
      "shell:default",
      "shell:allow-open",
      "os:default",
      "notification:default"
    ]
  }
}
