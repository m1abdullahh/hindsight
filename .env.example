# Postgres — Neon serverless connection string
# Create a project at https://console.neon.tech, copy the pooled or direct URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# Postgres — separate Neon branch used by `pnpm db:test:migrate` and the test suite.
# Create a branch in the Neon console (e.g. "test") and paste its URL here.
TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME-test?sslmode=require

# Redis — Upstash serverless connection string (rediss:// for TLS).
# Create a database at https://console.upstash.com.
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

# API
NODE_ENV=development
PORT=3001
PUBLIC_API_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:5173

# Web
VITE_API_URL=http://localhost:3001

# R2 (filled when ingestion plan lands)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Mail — pick ONE transport.
#
# Shared settings:
MAIL_FROM="Hindsight <noreply@hindsight.app>"
#
# Option A — Resend (HTTP API). Set this single var.
MAIL_PROVIDER_API_KEY=
#
# Option B — SMTP (Gmail, Mailgun, Mailtrap, self-hosted, etc.).
# When SMTP_HOST is set, SMTP wins over Resend.
# Common configurations:
#   • Mailtrap (dev sandbox):   host=sandbox.smtp.mailtrap.io  port=2525  secure=false
#   • Gmail (app password):     host=smtp.gmail.com            port=587   secure=false
#   • Mailgun:                  host=smtp.mailgun.org          port=587   secure=false
#   • SES (region-specific):    host=email-smtp.<region>.amazonaws.com port=587 secure=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false   # set "true" only for implicit TLS on port 465
